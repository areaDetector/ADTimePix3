  <widget type="image" version="2.0.0">
    <name>Image_Accumulated_512</name>
    <pv_name>$(P)$(R)ImageData</pv_name>
    <x>680</x>
    <y>750</y>
    <width>700</width>
    <height>700</height>
    <visible>false</visible>
    <x_axis>
      <visible>true</visible>
      <title>X (Width)</title>
      <minimum>0.0</minimum>
      <maximum>512.0</maximum>
      <title_font>
        <font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0">
        </font>
      </title_font>
      <scale_font>
        <font name="Default" family="Liberation Sans" style="REGULAR" size="14.0">
        </font>
      </scale_font>
    </x_axis>
    <y_axis>
      <visible>true</visible>
      <title>Y (Height)</title>
      <minimum>0.0</minimum>
      <maximum>512.0</maximum>
      <title_font>
        <font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0">
        </font>
      </title_font>
      <scale_font>
        <font name="Default" family="Liberation Sans" style="REGULAR" size="14.0">
        </font>
      </scale_font>
    </y_axis>
    <rules>
      <rule name="vis512" prop_id="visible" out_exp="false">
        <exp bool_exp="pv0==262144">
          <value>true</value>
        </exp>
        <pv_name>$(P)$(Cam)PixCount_RBV</pv_name>
      </rule>
    </rules>
    <data_width>512</data_width>
    <data_height>512</data_height>
  </widget>
