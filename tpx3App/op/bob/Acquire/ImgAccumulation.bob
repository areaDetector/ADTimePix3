<?xml version="1.0" encoding="UTF-8"?>
<display version="2.0.0">
  <name>ImgAccumulation</name>
  <macros>
    <R>cam1:Img</R>
    <!-- Detector record prefix for PixCount_RBV (same as ADTimePix3.template); not the Img channel suffix. -->
    <Cam>cam1:</Cam>
  </macros>
  <width>2135</width>
  <height>1455</height>
  <widget type="group" version="3.0.0">
    <name>TPX3_Image_Control</name>
    <width>1400</width>
    <height>710</height>
      <widget type="label" version="2.0.0">
        <name>RasterHint</name>
        <text>Image raster: 256×256 vs 512×512 is selected automatically from $(P)$(Cam)PixCount_RBV (65536 vs 262144), same as Mask.bob.</text>
        <x>50</x>
        <y>62</y>
        <width>1200</width>
        <height>22</height>
        <font>
          <font family="Liberation Sans" style="REGULAR" size="12.0">
          </font>
        </font>
        <foreground_color>
          <color red="80" green="80" blue="80">
          </color>
        </foreground_color>
        <transparent>true</transparent>
      </widget>
      <widget type="label" version="2.0.0">
        <name>Title</name>
        <text>ADTimePix3 Image Accumulation Control Panel</text>
      <x>50</x>
      <y>20</y>
      <width>1300</width>
      <height>40</height>
      <font>
        <font family="Liberation Sans" style="BOLD" size="28.0">
        </font>
      </font>
      <foreground_color>
        <color red="255" green="255" blue="255">
        </color>
      </foreground_color>
      <background_color>
        <color red="30" green="144" blue="255">
        </color>
      </background_color>
      <transparent>false</transparent>
    </widget>
    <widget type="group" version="3.0.0">
      <name>AcquisitionControl</name>
      <x>10</x>
      <y>80</y>
      <width>1350</width>
      <height>100</height>
      <widget type="label" version="2.0.0">
        <name>AcquisitionControlLabel</name>
        <text>Acquisition Control</text>
        <x>10</x>
        <y>10</y>
        <width>200</width>
        <background_color>
          <color red="240" green="240" blue="240">
          </color>
        </background_color>
        <border_width>1</border_width>
        <border_color>
          <color red="0" green="128" blue="255">
          </color>
        </border_color>
      </widget>
      <widget type="label" version="2.0.0">
        <name>EnableLabel</name>
        <text>Enable Accumulation:</text>
        <x>20</x>
        <y>40</y>
        <width>200</width>
        <height>25</height>
      </widget>
      <widget type="bool_button" version="2.0.0">
        <name>AccumulationEnableButton</name>
        <pv_name>$(P)$(R)AccumulationEnable</pv_name>
        <bit>-1</bit>
        <x>230</x>
        <y>38</y>
        <height>25</height>
        <off_label>Disabled</off_label>
        <off_color>
          <color red="200" green="100" blue="100">
          </color>
        </off_color>
        <on_label>Enabled</on_label>
        <on_color>
          <color red="100" green="200" blue="100">
          </color>
        </on_color>
        <background_color>
          <color red="240" green="240" blue="240">
          </color>
        </background_color>
        <actions>
        </actions>
      </widget>
      <widget type="textupdate" version="2.0.0">
        <name>AccumulationEnableStatus</name>
        <pv_name>$(P)$(R)AccumulationEnable_RBV</pv_name>
        <x>340</x>
        <y>38</y>
        <height>25</height>
        <vertical_alignment>1</vertical_alignment>
      </widget>
      <widget type="label" version="2.0.0">
        <name>ResetLabel</name>
        <text>Reset Accumulation:</text>
        <x>300</x>
        <y>5</y>
        <width>160</width>
        <height>25</height>
        <vertical_alignment>1</vertical_alignment>
      </widget>
      <widget type="bool_button" version="2.0.0">
        <name>ImageDataResetButton</name>
        <pv_name>$(P)$(R)ImageDataReset</pv_name>
        <bit>-1</bit>
        <x>460</x>
        <y>3</y>
        <height>25</height>
        <off_label>No</off_label>
        <off_color>
          <color red="240" green="240" blue="240">
          </color>
        </off_color>
        <on_label>Reset</on_label>
        <on_color>
          <color red="255" green="100" blue="100">
          </color>
        </on_color>
        <background_color>
          <color red="240" green="240" blue="240">
          </color>
        </background_color>
        <actions>
        </actions>
      </widget>
      <widget type="label" version="2.0.0">
        <name>NoteLabel</name>
        <text>Note: When disabled, images can be written to disk/NDArray callbacks but accumulation processing is skipped.</text>
        <x>450</x>
        <y>40</y>
        <width>890</width>
        <height>25</height>
        <foreground_color>
          <color red="100" green="100" blue="100">
          </color>
        </foreground_color>
        <vertical_alignment>1</vertical_alignment>
      </widget>
      <widget type="label" version="2.0.0">
        <name>WriteProcessedLabel</name>
        <text>Push to file (addr 2,3):</text>
        <x>614</x>
        <y>5</y>
        <width>160</width>
        <height>25</height>
      </widget>
      <widget type="bool_button" version="2.0.0">
        <name>WriteProcessedImgButton</name>
        <pv_name>$(P)cam1:WriteProcessedImg</pv_name>
        <bit>-1</bit>
        <x>784</x>
        <y>3</y>
        <height>25</height>
        <off_label>No</off_label>
        <off_color>
          <color red="240" green="240" blue="240">
          </color>
        </off_color>
        <on_label>Write</on_label>
        <on_color>
          <color red="100" green="200" blue="255">
          </color>
        </on_color>
        <background_color>
          <color red="240" green="240" blue="240">
          </color>
        </background_color>
        <actions>
        </actions>
      </widget>
      <widget type="label" version="2.0.0">
        <name>ProcessedOutputTypeLabel</name>
        <text>Output type:</text>
        <x>914</x>
        <y>5</y>
        <width>90</width>
        <height>25</height>
      </widget>
      <widget type="combo" version="2.0.0">
        <name>ProcessedImgOutputTypeCombo</name>
        <pv_name>$(P)cam1:ProcessedImgOutputType</pv_name>
        <x>1009</x>
        <y>3</y>
        <width>200</width>
        <height>25</height>
        <background_color>
          <color red="255" green="255" blue="200">
          </color>
        </background_color>
        <items>
          <item>Sum (64-bit)</item>
          <item>Average (32-bit)</item>
        </items>
      </widget>
    </widget>
