<?xml version="1.0" encoding="UTF-8"?>
<display version="2.0.0">
  <name>PixelConfig vs BPC</name>
  <width>1040</width>
  <height>1660</height>
  <background_color>
    <color red="240" green="240" blue="240">
    </color>
  </background_color>
  <grid_step_x>5</grid_step_x>
  <grid_step_y>5</grid_step_y>
  <widget type="label" version="2.0.0">
    <name>Title</name>
    <text>SERVAL PixelConfig vs disk BPC</text>
    <x>5</x>
    <y>5</y>
    <width>400</width>
    <height>22</height>
    <font>
      <font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0">
      </font>
    </font>
    <foreground_color>
      <color red="0" green="0" blue="180">
      </color>
    </foreground_color>
    <vertical_alignment>1</vertical_alignment>
    <wrap_words>false</wrap_words>
    <actions>
    </actions>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Hint</name>
    <text>Uses BPCFilePath/BPCFileName. |byte_SERVAL − byte_BPC| heatmap updates after refresh.</text>
    <x>5</x>
    <y>28</y>
    <width>650</width>
    <height>36</height>
    <foreground_color>
      <color red="60" green="60" blue="60">
      </color>
    </foreground_color>
    <actions>
    </actions>
  </widget>
  <widget type="bool_button" version="2.0.0">
    <name>RefreshPixelConfigBtn</name>
    <pv_name>$(Sys)$(Dev)$(Cam)RefreshPixelConfig</pv_name>
    <bit>-1</bit>
    <x>420</x>
    <y>3</y>
    <width>120</width>
    <height>28</height>
    <off_label>Refresh</off_label>
    <off_color>
      <color red="220" green="220" blue="240">
      </color>
    </off_color>
    <on_label>Go</on_label>
    <on_color>
      <color red="120" green="200" blue="255">
      </color>
    </on_color>
    <background_color>
      <color red="240" green="240" blue="240">
      </color>
    </background_color>
    <actions>
    </actions>
  </widget>
