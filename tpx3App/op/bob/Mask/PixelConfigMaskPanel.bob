  <widget type="label" version="2.0.0">
    <name>ImgLab512</name>
    <text>|Δ| (512×512)</text>
    <x>5</x>
    <y>288</y>
    <width>120</width>
    <font>
      <font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0">
      </font>
    </font>
    <foreground_color>
      <color red="0" green="0" blue="200">
      </color>
    </foreground_color>
    <vertical_alignment>1</vertical_alignment>
    <wrap_words>false</wrap_words>
    <actions>
    </actions>
    <rules>
      <rule name="visLab512" prop_id="visible" out_exp="false">
        <exp bool_exp="pv0==262144">
          <value>true</value>
        </exp>
        <pv_name>$(Sys)$(Dev)$(Cam)PixCount_RBV</pv_name>
      </rule>
    </rules>
  </widget>
  <widget type="image" version="2.0.0">
    <name>PixelConfigDiff512</name>
    <pv_name>$(Sys)$(Dev)$(Cam)PixelConfigDiff</pv_name>
    <x>5</x>
    <y>310</y>
    <width>512</width>
    <height>512</height>
    <visible>false</visible>
    <background_color>
      <color name="Transparent" red="255" green="255" blue="255" alpha="0">
      </color>
    </background_color>
    <color_map>
      <name>JET</name>
    </color_map>
    <x_axis>
      <visible>true</visible>
      <title>X</title>
      <minimum>0.0</minimum>
      <maximum>512.0</maximum>
      <title_font>
        <font name="Default" family="Liberation Sans" style="REGULAR" size="14.0">
        </font>
      </title_font>
      <scale_font>
        <font name="Default" family="Liberation Sans" style="REGULAR" size="14.0">
        </font>
      </scale_font>
    </x_axis>
    <y_axis>
      <visible>true</visible>
      <title>Y</title>
      <minimum>512.0</minimum>
      <maximum>0.0</maximum>
      <title_font>
        <font name="Default" family="Liberation Sans" style="REGULAR" size="14.0">
        </font>
      </title_font>
      <scale_font>
        <font name="Default" family="Liberation Sans" style="REGULAR" size="14.0">
        </font>
      </scale_font>
    </y_axis>
    <actions>
    </actions>
    <rules>
      <rule name="vis512" prop_id="visible" out_exp="false">
        <exp bool_exp="pv0==262144">
          <value>true</value>
        </exp>
        <pv_name>$(Sys)$(Dev)$(Cam)PixCount_RBV</pv_name>
      </rule>
    </rules>
    <border_alarm_sensitive>false</border_alarm_sensitive>
    <data_width>512</data_width>
    <data_height>512</data_height>
  </widget>
